# ─────────────────────────────────────────────
# DataBuddy — Environment Configuration
# Copy file ini jadi .env dan isi nilai-nilainya
# ─────────────────────────────────────────────

# App
APP_NAME=DataBuddy
APP_ENV=development   # development | production

# Supabase (isi setelah project Supabase dibuat)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# LLM (isi salah satu yang dipakai)
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key

# Database Lokal (SQLite — default, tidak perlu diubah)
LOCAL_DB_PATH=data/local.db

# Upload
MAX_UPLOAD_SIZE_MB=200
